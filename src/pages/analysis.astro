---
import Layout from '../layouts/Layout.astro';
import SubjectChart from '../components/SubjectChart';
import type { Env } from '../types';
import { BarChart3, CheckCircle, Clock, XCircle } from 'lucide-react';

interface SubjectStat {
  subject_name: string;
  category: string;
  total_correct: number;
  total_wrong: number;
  total_blank: number;
  appearance_count: number;
  wrong_rate: number;
}

interface SpeedStats {
  avg_time_per_question: number;
  sayisal_time_per_question: number;
  sozel_time_per_question: number;
}

let subjectStats: SubjectStat[] = [];
let speedStats: SpeedStats = {
  avg_time_per_question: 0,
  sayisal_time_per_question: 0,
  sozel_time_per_question: 0,
};

try {
  const { env } = await import('cloudflare:workers');
  const db = (env as Env).DB;

  const { results } = await db
    .prepare(
      `
    SELECT subject_name, category,
           SUM(correct) as total_correct,
           SUM(wrong) as total_wrong,
           SUM(blank) as total_blank,
           COUNT(*) as appearance_count,
           ROUND(CAST(SUM(wrong) AS FLOAT) / NULLIF(SUM(correct) + SUM(wrong), 0) * 100, 1) as wrong_rate
    FROM exam_subjects
    GROUP BY subject_name, category
    ORDER BY wrong_rate DESC
  `,
    )
    .all<SubjectStat>();
  subjectStats = results || [];

  // DGS özelinde daha basit bir yaklaşım: Toplam süre / Toplam Soru
  const totalStats = await db
    .prepare(
      `
    SELECT
      SUM(time_spent) as total_time,
      SUM(sayisal_correct + sayisal_wrong) as total_sayisal_q,
      SUM(sozel_correct + sozel_wrong) as total_sozel_q
    FROM exams WHERE time_spent > 0
  `,
    )
    .first();

  if (totalStats && (totalStats.total_time as number) > 0) {
    const tTime = (totalStats.total_time as number) || 0;
    const tSay = (totalStats.total_sayisal_q as number) || 0;
    const tSoz = (totalStats.total_sozel_q as number) || 0;

    speedStats = {
      avg_time_per_question: Math.round((tTime / (tSay + tSoz)) * 100) / 100,
      sayisal_time_per_question:
        tSay > 0 ? Math.round(((tTime * (tSay / (tSay + tSoz))) / tSay) * 100) / 100 : 0,
      sozel_time_per_question:
        tSoz > 0 ? Math.round(((tTime * (tSoz / (tSay + tSoz))) / tSoz) * 100) / 100 : 0,
    };
  }
} catch (e) {
  console.error('DB error:', e);
}

const sayisalStats = subjectStats.filter((s) => s.category === 'sayisal');
const sozelStats = subjectStats.filter((s) => s.category === 'sozel');
---

<Layout title="Konu Analizi" activeNav="analysis">
  <div class="mb-8">
    <h1 class="mb-2 text-2xl font-extrabold">Konu Bazlı Analiz</h1>
    <p class="text-sm text-slate-500">Tüm denemelerindeki konu performansını incele.</p>
  </div>

  {
    subjectStats.length > 0 ? (
      <Fragment>
        <div class="mb-6 grid grid-cols-1 gap-6 md:grid-cols-3">
          <div class="rounded-2xl border border-white/[0.06] bg-slate-900/60 p-6 md:col-span-2">
            <h2 class="mb-4 text-lg font-bold">Tüm Konular (Yanlış Oranına Göre)</h2>
            <SubjectChart stats={subjectStats} filter="all" client:load />
          </div>

          <div class="flex flex-col justify-center rounded-2xl border border-white/[0.06] bg-slate-900/60 p-6">
            <div class="mb-4 flex items-center gap-2">
              <div class="rounded-lg bg-amber-500/10 p-2">
                <Clock className="w-5 h-5 text-amber-400" />
              </div>
              <h2 class="text-lg font-bold">Hız Analizi</h2>
            </div>
            <div class="space-y-6">
              <div>
                <div class="mb-1 text-xs font-semibold text-slate-500 uppercase">
                  Soru Başına Ortalama
                </div>
                <div class="text-3xl font-black text-amber-400">
                  {speedStats.avg_time_per_question}{' '}
                  <span class="text-sm font-bold text-slate-500">dk</span>
                </div>
              </div>
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <div class="mb-1 text-[10px] font-semibold text-slate-500 uppercase">
                    Sayısal Hız
                  </div>
                  <div class="text-lg font-bold text-blue-400">
                    {speedStats.avg_time_per_question}{' '}
                    <span class="text-xs text-slate-500">dk</span>
                  </div>
                </div>
                <div>
                  <div class="mb-1 text-[10px] font-semibold text-slate-500 uppercase">
                    Sözel Hız
                  </div>
                  <div class="text-lg font-bold text-indigo-400">
                    {speedStats.avg_time_per_question}{' '}
                    <span class="text-xs text-slate-500">dk</span>
                  </div>
                </div>
              </div>
              <p class="text-[10px] leading-relaxed text-slate-600 italic">
                * Bu veriler süre girdiğin denemeler üzerinden hesaplanmıştır. DGS'de hedef 1.2 dk
                altıdır.
              </p>
            </div>
          </div>
        </div>

        <div class="mb-6 grid grid-cols-1 gap-6 md:grid-cols-2">
          <div class="rounded-2xl border border-white/[0.06] bg-slate-900/60 p-6">
            <h2 class="mb-4 text-lg font-bold">Sayısal Konular</h2>
            {sayisalStats.length > 0 ? (
              <div class="space-y-2">
                {sayisalStats.map((s) => (
                  <div class="flex items-center justify-between rounded-lg px-3 py-2 transition-colors hover:bg-white/[0.04]">
                    <div>
                      <div class="text-sm font-medium text-slate-300">{s.subject_name}</div>
                      <div class="text-[10px] text-slate-600">{s.appearance_count} denemede</div>
                    </div>
                    <div class="flex items-center gap-3">
                      <div class="flex items-center gap-3 text-xs">
                        <span class="flex items-center gap-1">
                          <CheckCircle className="w-3 h-3 text-emerald-400" />
                          {s.total_correct}
                        </span>
                        <span class="flex items-center gap-1">
                          <XCircle className="w-3 h-3 text-red-400" />
                          {s.total_wrong}
                        </span>
                      </div>
                      <div
                        class={`rounded-full px-2 py-0.5 text-xs font-bold ${
                          s.wrong_rate > 50
                            ? 'bg-red-500/20 text-red-400'
                            : s.wrong_rate > 30
                              ? 'bg-amber-500/20 text-amber-400'
                              : 'bg-emerald-500/20 text-emerald-400'
                        }`}
                      >
                        %{s.wrong_rate || 0}
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            ) : (
              <p class="py-8 text-center text-sm text-slate-500">Veri yok</p>
            )}
          </div>

          <div class="rounded-2xl border border-white/[0.06] bg-slate-900/60 p-6">
            <h2 class="mb-4 text-lg font-bold">Sözel Konular</h2>
            {sozelStats.length > 0 ? (
              <div class="space-y-2">
                {sozelStats.map((s) => (
                  <div class="flex items-center justify-between rounded-lg px-3 py-2 transition-colors hover:bg-white/[0.04]">
                    <div>
                      <div class="text-sm font-medium text-slate-300">{s.subject_name}</div>
                      <div class="text-[10px] text-slate-600">{s.appearance_count} denemede</div>
                    </div>
                    <div class="flex items-center gap-3">
                      <div class="flex items-center gap-3 text-xs">
                        <span class="flex items-center gap-1">
                          <CheckCircle className="w-3 h-3 text-emerald-400" />
                          {s.total_correct}
                        </span>
                        <span class="flex items-center gap-1">
                          <XCircle className="w-3 h-3 text-red-400" />
                          {s.total_wrong}
                        </span>
                      </div>
                      <div
                        class={`rounded-full px-2 py-0.5 text-xs font-bold ${
                          s.wrong_rate > 50
                            ? 'bg-red-500/20 text-red-400'
                            : s.wrong_rate > 30
                              ? 'bg-amber-500/20 text-amber-400'
                              : 'bg-emerald-500/20 text-emerald-400'
                        }`}
                      >
                        %{s.wrong_rate || 0}
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            ) : (
              <p class="py-8 text-center text-sm text-slate-500">Veri yok</p>
            )}
          </div>
        </div>
      </Fragment>
    ) : (
      <div class="py-20 text-center">
        <BarChart3 className="mb-4 w-16 h-16 text-blue-400 mx-auto opacity-50" />
        <h2 class="mb-2 text-xl font-bold">Henüz analiz verisi yok</h2>
        <p class="mb-6 text-sm text-slate-500">
          Deneme eklerken konu bazlı detayları da girersen burada analiz göreceksin.
        </p>
        <a
          href="/exam/new"
          class="inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-blue-500 to-sky-400 px-6 py-3 text-sm font-bold text-white no-underline shadow-[0_0_20px_rgba(59,130,246,0.3)] transition-all hover:-translate-y-0.5"
        >
          + Deneme Ekle
        </a>
      </div>
    )
  }
</Layout>
