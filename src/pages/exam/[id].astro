---
import Layout from '../../layouts/Layout.astro';

const { id } = Astro.params;
const db = (Astro.locals as any).runtime?.env?.DB;

let exam: any = null;
let subjects: any[] = [];

try {
  if (db && id) {
    exam = await db.prepare('SELECT * FROM exams WHERE id = ?').bind(id).first();
    const { results } = await db
      .prepare('SELECT * FROM exam_subjects WHERE exam_id = ? ORDER BY category, id')
      .bind(id)
      .all();
    subjects = results || [];
  }
} catch (e) {
  console.error('DB error:', e);
}

if (!exam) {
  return Astro.redirect('/history');
}

const sayisalSubjects = subjects.filter((s: any) => s.category === 'sayisal');
const sozelSubjects = subjects.filter((s: any) => s.category === 'sozel');
---

<Layout title={exam.name} activeNav="">
  <div class="mb-6">
    <a href="/history" class="text-xs text-violet-400 no-underline hover:text-violet-300"
      >← Geçmişe Dön</a
    >
  </div>

  <!-- Header -->
  <div class="mb-6 rounded-2xl border border-white/[0.06] bg-slate-900/60 p-6">
    <div class="flex flex-wrap items-center justify-between gap-4">
      <div>
        <h1 class="mb-1 text-2xl font-extrabold">{exam.name}</h1>
        <div class="flex gap-3 text-xs text-slate-500">
          <span
            >{
              new Date(exam.exam_date).toLocaleDateString('tr-TR', {
                day: 'numeric',
                month: 'long',
                year: 'numeric',
              })
            }</span
          >
          {exam.publisher && <span>• {exam.publisher}</span>}
        </div>
      </div>
      <div class="text-right">
        <div class="mb-1 text-xs tracking-wider text-slate-500 uppercase">Toplam Net</div>
        <div
          class={`text-4xl font-black ${exam.total_net >= 0 ? 'bg-gradient-to-r from-violet-400 to-blue-400 bg-clip-text text-transparent' : 'text-red-400'}`}
        >
          {exam.total_net.toFixed(1)}
        </div>
      </div>
    </div>
  </div>

  <!-- Net Cards -->
  <div class="mb-6 grid grid-cols-1 gap-4 md:grid-cols-2">
    <div
      class="rounded-2xl border border-t-2 border-white/[0.06] border-t-blue-500 bg-slate-900/60 p-6"
    >
      <div class="mb-3 text-xs font-semibold tracking-wide text-slate-500 uppercase">
        🔢 Sayısal
      </div>
      <div
        class={`text-3xl font-extrabold mb-3 ${exam.sayisal_net >= 0 ? 'text-blue-400' : 'text-red-400'}`}
      >
        {exam.sayisal_net.toFixed(1)}
        <span class="text-sm font-normal text-slate-500">net</span>
      </div>
      <div class="flex gap-4 text-sm">
        <span class="text-emerald-400">✅ {exam.sayisal_correct}</span>
        <span class="text-red-400">❌ {exam.sayisal_wrong}</span>
        <span class="text-slate-500">⬜ {exam.sayisal_blank}</span>
      </div>
    </div>
    <div
      class="rounded-2xl border border-t-2 border-white/[0.06] border-t-amber-500 bg-slate-900/60 p-6"
    >
      <div class="mb-3 text-xs font-semibold tracking-wide text-slate-500 uppercase">📝 Sözel</div>
      <div
        class={`text-3xl font-extrabold mb-3 ${exam.sozel_net >= 0 ? 'text-amber-400' : 'text-red-400'}`}
      >
        {exam.sozel_net.toFixed(1)}
        <span class="text-sm font-normal text-slate-500">net</span>
      </div>
      <div class="flex gap-4 text-sm">
        <span class="text-emerald-400">✅ {exam.sozel_correct}</span>
        <span class="text-red-400">❌ {exam.sozel_wrong}</span>
        <span class="text-slate-500">⬜ {exam.sozel_blank}</span>
      </div>
    </div>
  </div>

  <!-- Konu Detayları -->
  {
    subjects.length > 0 && (
      <div class="mb-6 rounded-2xl border border-white/[0.06] bg-slate-900/60 p-6">
        <h2 class="mb-4 text-lg font-bold">📊 Konu Bazlı Detay</h2>

        {sayisalSubjects.length > 0 && (
          <div class="mb-6">
            <h3 class="mb-3 text-sm font-bold tracking-wide text-blue-400 uppercase">🔢 Sayısal</h3>
            <div class="space-y-1">
              {sayisalSubjects.map((s: any) => (
                <div class="flex items-center justify-between rounded-lg px-3 py-2 transition-colors hover:bg-white/[0.03]">
                  <span class="text-sm text-slate-300">{s.subject_name}</span>
                  <div class="flex gap-3 text-sm">
                    <span class="text-emerald-400">✅ {s.correct}</span>
                    <span class="text-red-400">❌ {s.wrong}</span>
                    <span class="text-slate-500">⬜ {s.blank}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        {sozelSubjects.length > 0 && (
          <div>
            <h3 class="mb-3 text-sm font-bold tracking-wide text-amber-400 uppercase">📝 Sözel</h3>
            <div class="space-y-1">
              {sozelSubjects.map((s: any) => (
                <div class="flex items-center justify-between rounded-lg px-3 py-2 transition-colors hover:bg-white/[0.03]">
                  <span class="text-sm text-slate-300">{s.subject_name}</span>
                  <div class="flex gap-3 text-sm">
                    <span class="text-emerald-400">✅ {s.correct}</span>
                    <span class="text-red-400">❌ {s.wrong}</span>
                    <span class="text-slate-500">⬜ {s.blank}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    )
  }

  <!-- Notlar -->
  {
    exam.notes && (
      <div class="mb-6 rounded-2xl border border-white/[0.06] bg-slate-900/60 p-6">
        <h2 class="mb-2 text-lg font-bold">📌 Notlar</h2>
        <p class="text-sm whitespace-pre-wrap text-slate-400">{exam.notes}</p>
      </div>
    )
  }

  <!-- Sil Butonu -->
  <div class="text-center">
    <button
      id="delete-btn"
      class="inline-flex cursor-pointer items-center gap-2 rounded-lg border border-red-500/20 bg-red-500/10 px-5 py-2.5 text-sm font-semibold text-red-400 transition-all hover:bg-red-500/20"
    >
      🗑️ Denemeyi Sil
    </button>
  </div>

  <script define:vars={{ examId: id }}>
    document.getElementById('delete-btn')?.addEventListener('click', async () => {
      if (!confirm('Bu denemeyi silmek istediğine emin misin?')) return;
      const res = await fetch(`/api/exams/${examId}`, { method: 'DELETE' });
      if (res.ok) window.location.href = '/history';
    });
  </script>
</Layout>
