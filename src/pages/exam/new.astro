---
import Layout from '../../layouts/Layout.astro';
import ExamForm from '../../components/ExamForm';
import { FileEdit } from 'lucide-react';
---

<Layout title="Yeni Deneme" activeNav="new-exam">
  <div class="mb-8 flex items-center gap-3">
    <FileEdit className="h-8 w-8 text-blue-400" />
    <div>
      <h1 class="mb-1 text-2xl font-extrabold">Yeni Deneme Ekle</h1>
      <p class="text-sm text-slate-500">Deneme sonuçlarını girerek performansını takip et.</p>
    </div>
  </div>
  <ExamForm client:load />
</Layout>
