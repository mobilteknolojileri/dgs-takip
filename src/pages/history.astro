---
import Layout from '../layouts/Layout.astro';
import type { Env, ExamRecord } from '../types';
import { ClipboardList } from 'lucide-react';

let exams: ExamRecord[] = [];

try {
  const { env } = await import('cloudflare:workers');
  const db = (env as Env).DB;
  const { results } = await db
    .prepare('SELECT * FROM exams ORDER BY exam_date DESC')
    .all<ExamRecord>();
  exams = results || [];
} catch (e) {
  console.error('DB error:', e);
}
---

<Layout title="Deneme Geçmişi" activeNav="history">
  <div class="mb-8 flex items-center justify-between">
    <div>
      <h1 class="mb-2 text-2xl font-extrabold">Deneme Geçmişi</h1>
      <p class="text-sm text-slate-500">Tüm denemelerini burada görebilirsin.</p>
    </div>
    <a
      href="/exam/new"
      class="inline-flex items-center gap-2 rounded-lg bg-gradient-to-r from-blue-500 to-sky-400 px-5 py-2.5 text-sm font-semibold text-white no-underline shadow-[0_0_20px_rgba(59,130,246,0.3)] transition-all hover:-translate-y-0.5"
    >
      + Ekle
    </a>
  </div>

  {
    exams.length > 0 ? (
      <div class="overflow-hidden rounded-2xl border border-white/[0.06] bg-slate-900/60">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-white/[0.06]">
                <th class="px-5 py-3 text-left text-[11px] font-bold tracking-wide text-slate-500 uppercase">
                  Deneme
                </th>
                <th class="px-5 py-3 text-left text-[11px] font-bold tracking-wide text-slate-500 uppercase">
                  Tarih
                </th>
                <th class="px-5 py-3 text-left text-[11px] font-bold tracking-wide text-slate-500 uppercase">
                  Yayınevi
                </th>
                <th class="px-5 py-3 text-center text-[11px] font-bold tracking-wide text-blue-400 uppercase">
                  Sayısal
                </th>
                <th class="px-5 py-3 text-center text-[11px] font-bold tracking-wide text-amber-400 uppercase">
                  Sözel
                </th>
                <th class="px-5 py-3 text-center text-[11px] font-bold tracking-wide text-blue-400 uppercase">
                  Toplam
                </th>
                <th class="px-5 py-3 text-center text-[11px] font-bold tracking-wide text-amber-500 uppercase">
                  Süre
                </th>
              </tr>
            </thead>
            <tbody>
              {exams.map((exam) => (
                <tr
                  class="cursor-pointer border-b border-white/[0.03] transition-colors hover:bg-white/[0.03]"
                  onclick={`window.location.href='/exam/${exam.id}'`}
                >
                  <td class="px-5 py-4">
                    <div class="text-sm font-semibold text-slate-200">{exam.name}</div>
                  </td>
                  <td class="px-5 py-4 text-sm text-slate-400">
                    {new Date(exam.exam_date).toLocaleDateString('tr-TR')}
                  </td>
                  <td class="px-5 py-4 text-sm text-slate-500">{exam.publisher || '-'}</td>
                  <td class="px-5 py-4 text-center">
                    <span
                      class={`text-sm font-bold ${exam.sayisal_net >= 0 ? 'text-blue-400' : 'text-red-400'}`}
                    >
                      {exam.sayisal_net.toFixed(1)}
                    </span>
                    <div class="text-[10px] text-slate-600">
                      {exam.sayisal_correct}D {exam.sayisal_wrong}Y
                    </div>
                  </td>
                  <td class="px-5 py-4 text-center">
                    <span
                      class={`text-sm font-bold ${exam.sozel_net >= 0 ? 'text-amber-400' : 'text-red-400'}`}
                    >
                      {exam.sozel_net.toFixed(1)}
                    </span>
                    <div class="text-[10px] text-slate-600">
                      {exam.sozel_correct}D {exam.sozel_wrong}Y
                    </div>
                  </td>
                  <td class="px-5 py-4 text-center">
                    <span
                      class={`text-lg font-extrabold ${exam.total_net >= 0 ? 'text-emerald-400' : 'text-red-400'}`}
                    >
                      {exam.total_net.toFixed(1)}
                    </span>
                  </td>
                  <td class="px-5 py-4 text-center">
                    {exam.time_spent > 0 ? (
                      <div class="flex items-center justify-center gap-1 text-sm font-bold text-amber-500">
                        {exam.time_spent}{' '}
                        <span class="text-[10px] font-normal text-slate-500 uppercase">dk</span>
                      </div>
                    ) : (
                      <span class="text-slate-700">-</span>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    ) : (
      <div class="py-20 text-center">
        <ClipboardList className="mb-4 w-16 h-16 text-blue-400 mx-auto opacity-50" />
        <h2 class="mb-2 text-xl font-bold">Henüz deneme eklenmemiş</h2>
        <p class="mb-6 text-sm text-slate-500">İlk denemeni ekleyerek başla!</p>
        <a
          href="/exam/new"
          class="inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-blue-500 to-sky-400 px-6 py-3 text-sm font-bold text-white no-underline shadow-[0_0_20px_rgba(59,130,246,0.3)] transition-all hover:-translate-y-0.5"
        >
          + İlk Denemeyi Ekle
        </a>
      </div>
    )
  }
</Layout>
