---
import { Activity, Grip, History, PlusSquare } from 'lucide-react';

interface Props {
  title: string;
  activeNav?: string;
}

const { title, activeNav = '' } = Astro.props;
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="DGS Deneme Takip - Sınav performansını analiz et" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | DGS Takip</title>
  </head>
  <body class="min-h-screen font-sans text-slate-100 antialiased">
    <div class="relative z-10 mx-auto max-w-6xl px-5">
      <!-- Navbar -->
      <nav
        class="sticky top-0 z-50 -mx-5 mb-8 flex flex-col items-center justify-between gap-4 border-b border-white/[0.06] bg-[#0a0a1a]/85 px-5 py-4 backdrop-blur-xl sm:flex-row sm:gap-0"
      >
        <a href="/" class="no-underline">
          <div
            class="bg-gradient-to-r from-blue-500 to-sky-400 bg-clip-text text-center text-2xl font-extrabold text-transparent sm:text-left"
          >
            DGS Takip
          </div>
          <div
            class="text-center text-[10px] font-medium tracking-widest text-slate-500 uppercase sm:text-left"
          >
            19 Temmuz 2026
          </div>
        </a>
        <div
          class="flex w-full justify-center gap-1 overflow-x-auto pb-1 sm:w-auto sm:justify-end sm:overflow-visible sm:pb-0"
        >
          <a
            href="/"
            class:list={[
              'flex shrink-0 items-center gap-1.5 rounded-lg px-3 py-2 text-[13px] font-bold no-underline transition-all duration-200 sm:gap-2 sm:px-4 sm:text-sm',
              activeNav === 'dashboard'
                ? 'bg-blue-500/15 text-blue-300'
                : 'text-slate-300 hover:bg-white/[0.06] hover:text-white',
            ]}><Grip className="h-4 w-4" /> Panel</a
          >
          <a
            href="/exam/new"
            class:list={[
              'flex shrink-0 items-center gap-1.5 rounded-lg px-3 py-2 text-[13px] font-bold no-underline transition-all duration-200 sm:gap-2 sm:px-4 sm:text-sm',
              activeNav === 'new-exam'
                ? 'bg-blue-500/15 text-blue-300'
                : 'text-slate-300 hover:bg-white/[0.06] hover:text-white',
            ]}><PlusSquare className="h-4 w-4" /> Yeni Deneme</a
          >
          <a
            href="/analysis"
            class:list={[
              'flex shrink-0 items-center gap-1.5 rounded-lg px-3 py-2 text-[13px] font-bold no-underline transition-all duration-200 sm:gap-2 sm:px-4 sm:text-sm',
              activeNav === 'analysis'
                ? 'bg-blue-500/15 text-blue-300'
                : 'text-slate-300 hover:bg-white/[0.06] hover:text-white',
            ]}><Activity className="h-4 w-4" /> Analiz</a
          >
          <a
            href="/history"
            class:list={[
              'flex shrink-0 items-center gap-1.5 rounded-lg px-3 py-2 text-[13px] font-bold no-underline transition-all duration-200 sm:gap-2 sm:px-4 sm:text-sm',
              activeNav === 'history'
                ? 'bg-blue-500/15 text-blue-300'
                : 'text-slate-300 hover:bg-white/[0.06] hover:text-white',
            ]}><History className="h-4 w-4" /> Geçmiş</a
          >
        </div>
      </nav>

      <!-- Main Content -->
      <main>
        <slot />
      </main>

      <!-- Footer -->
      <footer class="py-10 text-center text-xs font-medium text-slate-500">
        DGS 2026 • 19 Temmuz
      </footer>
    </div>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
