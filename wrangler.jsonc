{
  "compatibility_date": "2026-04-02",
  "compatibility_flags": ["global_fetch_strictly_public"],
  "name": "deneme-analiz",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "dgs-takip-db",
      "database_id": "LOCAL_PLACEHOLDER",
    },
  ],
}
